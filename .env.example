# 91app Admin API — Required Environment Variables

# ===================================================================
# Auth Method 1: x-api-key（Cat.1-9 Admin API 核心）
# Obtain from: 91APP OMNI Admin Panel > API Key Management
# ===================================================================
APP_91APP_API_KEY=your_api_key_here
APP_91APP_BASE_URL=https://api.91app.com
APP_91APP_SHOP_ID=0

# ===================================================================
# Auth Method 2: n1-api-key（Cat.10-11 IMS, Cat.15 商品搜尋）
# Obtain from: 91APP IMS Admin Panel
# ===================================================================
APP_91APP_N1_API_KEY=your_n1_api_key_here
APP_91APP_IMS_BASE_URL=https://ims-api.91app.com

# ===================================================================
# Auth Method 3: N1-API-KEY + HMAC-SHA256（Cat.12-13 金流）
# Uses N1_API_KEY above + HMAC secret
# Obtain from: 91APP Payments Admin Panel
# ===================================================================
APP_91APP_HMAC_SECRET=your_hmac_secret_here
APP_91APP_PAYMENTS_BASE_URL=https://payments-api.91app.com

# ===================================================================
# Auth Method 4: ny-api-token（Cat.14 會員 Connect Cloud）
# Obtain from: 91APP Member Connect Cloud Admin Panel
# Fallback: uses N1_API_KEY if not set
# ===================================================================
APP_91APP_NY_API_TOKEN=your_ny_api_token_here
APP_91APP_MEMBER_BASE_URL=https://member-api.91app.com
